import { camera } from '@kit.CameraKit';

// 全局排队锁，确保多页面之间指令绝对同步
let globalCamTask: Promise<void> = Promise.resolve();

@Component
export struct MiniCameraPreview {
  @Prop @Watch('onActiveChange') isActive: boolean = false;
  @Prop componentId: string = 'cam';

  private xComponentController: XComponentController = new XComponentController();
  private surfaceId: string = '';
  private isHardwareReady: boolean = false;

  private cameraManager?: camera.CameraManager;
  private captureSession?: camera.Session;
  private cameraInput?: camera.CameraInput;
  private previewOutput?: camera.PreviewOutput;

  aboutToDisappear(): void {
    globalCamTask = globalCamTask.then(async (): Promise<void> => {
      await this._releaseAll();
      console.info(`[Camera ${this.componentId}] 组件销毁，硬件彻底释放`);
    }).catch((e: Error): void => { console.error(e.message); });
  }

  onActiveChange(): void {
    globalCamTask = globalCamTask.then(async (): Promise<void> => {
      if (this.isActive) {
        if (!this.isHardwareReady && this.surfaceId) {
          await this._initAll();
        }
        if (this.captureSession) {
          try { await this.captureSession.start(); } catch (e) {}
        }
      } else {
        // 🚨 核心修复：一旦页面说不需要相机了（比如加载页跳转走时），
        // 必须彻底调用 _releaseAll() 归还底层物理硬件！绝不能只 stop()。
        await this._releaseAll();
      }
    }).catch((e: Error): void => { console.error(e.message); });
  }

  private async _releaseAll(): Promise<void> {
    try { if (this.captureSession) { await this.captureSession.stop(); await this.captureSession.release(); } } catch (e) {}
    try { if (this.previewOutput) { await this.previewOutput.release(); } } catch (e) {}
    try { if (this.cameraInput) { await this.cameraInput.close(); } } catch (e) {}
    this.captureSession = undefined;
    this.previewOutput = undefined;
    this.cameraInput = undefined;
    this.isHardwareReady = false;
  }

  private async _initAll(retryCount: number = 0): Promise<void> {
    try {
      this.cameraManager = camera.getCameraManager(getContext(this));
      let cameras = this.cameraManager.getSupportedCameras();
      let frontCamera = cameras.find((c: camera.CameraDevice) => c.cameraPosition === camera.CameraPosition.CAMERA_POSITION_FRONT) || cameras[0];

      this.cameraInput = this.cameraManager.createCameraInput(frontCamera);
      await this.cameraInput.open();

      let profile = this.cameraManager.getSupportedOutputCapability(frontCamera, camera.SceneMode.NORMAL_PHOTO).previewProfiles[0];
      this.previewOutput = this.cameraManager.createPreviewOutput(profile, this.surfaceId);

      this.captureSession = this.cameraManager.createSession(camera.SceneMode.NORMAL_PHOTO);
      this.captureSession.beginConfig();
      this.captureSession.addInput(this.cameraInput);
      this.captureSession.addOutput(this.previewOutput);
      await this.captureSession.commitConfig();
      this.isHardwareReady = true;
    } catch (e) {
      console.error(`[Camera] 初始化异常: ${e}`);
      await this._releaseAll();
      // 失败重试逻辑（防止刚授权时系统反应不过来）
      if (this.isActive && retryCount < 5) {
        await new Promise<void>((resolve: Function): void => { setTimeout((): void => { resolve(); }, 300); });
        await this._initAll(retryCount + 1);
      }
    }
  }

  build() {
    Stack() {
      // 永远不卸载的常驻画布
      XComponent({
        id: this.componentId + '_surface', // 🚨 核心修复：使用绑定的静态ID，保证画布不被系统误杀
        type: 'surface',
        controller: this.xComponentController
      })
        .width('100%')
        .height('100%')
        .onLoad((): void => {
          this.surfaceId = this.xComponentController.getXComponentSurfaceId();
          if (this.isActive) {
            globalCamTask = globalCamTask.then(async (): Promise<void> => {
              if (this.isActive && !this.isHardwareReady) {
                await this._initAll();
                if (this.captureSession) await this.captureSession.start();
              }
            }).catch((e: Error): void => { console.error(e.message); });
          }
        })

      if (!this.isActive) {
        Column().width('100%').height('100%').backgroundColor('#000000')
      }
    }
    .width('100%')
    .height('100%')
    .backgroundColor('#000000')
  }
}
