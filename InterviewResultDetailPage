        { text: "\n\n最后虽然勉强解决了，但也导致了其他模块联调延期。这次经历让我深刻认识到风险及时暴露的重要性。", isHighlight: false } as AnswerSegment
      ]
    } as QuestionData
  ];

  getCardStyle(score: number): CardStyle {
    let isHigh = score >= 60;
    return {
      isHigh: isHigh,
      mainColor: isHigh ? '#004887' : '#69000B',
      faintColor: isHigh ? 'rgba(0, 72, 135, 0.25)' : 'rgba(105, 0, 11, 0.25)',
      highlightBg: '#FFF385',
      gradColor1: isHigh ? '#4E93EB' : '#FF928B',
      gradColor2: isHigh ? '#DFEBFF' : '#FFEEEE',
      gradColor3: '#FFF9F9',
      badgeBg: isHigh ? '#A8C9FF' : '#FFB3B3',
      shadowColor: isHigh ? 'rgba(78, 147, 235, 0.3)' : 'rgba(255, 146, 139, 0.3)'
    } as CardStyle;
  }

  @Builder
  HeaderView() {
    Column() {
      Row() {
        Image($r("app.media.456"))
          .width(40).height(40)
          .objectFit(ImageFit.Contain)
          .onClick(() => { RouterModule.pop(); })
        Text("作答情况")
          .fontSize(20)
          .fontWeight(FontWeight.Medium)
          .fontColor(AppTheme.TextBlack)
          .margin({ left: 8 })
        Blank()
      }
      .width('100%')
      .padding({ left: 16, right: 16, top: 10, bottom: 10 })
    }
    .width('100%')
    .backgroundColor('#F6F6F8')
  }

  build() {
    Column() {
      this.HeaderView()

      WaterFlow() {
        // 1. 大比分区域 (一起滚动)
        FlowItem() {
          Column() {
            Row() {
              Text("84")
                .fontSize(60)
                .fontWeight(FontWeight.Bold)
                .fontColor(AppTheme.TextBlack)
              Text("/100")
                .fontSize(36)
                .fontWeight(FontWeight.Medium)
                .fontColor('#2D2F31')
                .margin({ top: 12, left: 2 })
            }
            .width('100%')
            .padding({ left: 16, right: 16, top: 16 })

            Text("你的面试过程总共触及了 6 个关键问题，你的各项反馈有望于改进“面试”目标。")
              .fontSize(18)
              .fontColor('#5A5C5D')
              .lineHeight(29.25)
              .padding({ left: 16, right: 16, top: 8, bottom: 16 })
              .width('100%')
          }
          .width('100%')
          .backgroundColor('#F6F6F8')
        }

        // 2. 题目卡片列表
        ForEach(this.questions, (item: QuestionData) => {
          FlowItem() {
            QuestionCardView({
              item: item,
              cardStyle: this.getCardStyle(item.score)
            })
          }
        })

        // 3. 🌟 底部操作按钮 (移入 FlowItem，不再固定底部，一起滚动)
        FlowItem() {
          Column() {
            Button({ type: ButtonType.Capsule }) {
              Row({ space: 8 }) {
                Image($r("app.media.1616"))
                  .width(16).height(16)
                Text("返回结果总览")
                  .fontSize(20)
                  .fontWeight(FontWeight.Bold)
                  .fontColor("5B4B00")
              }
              .padding({ left: 24, right: 24 })
            }
            .width(220)
            .height(44)
            .backgroundColor(AppTheme.PrimaryYellow)
            .margin({ bottom: 12, top: 16 })
            .shadow({ radius: 10, color: 'rgba(255, 215, 0, 0.3)', offsetY: 4 })
            .onClick(() => {
              RouterModule.pop();
            })

            Row() {
              Text("准备好再来一场了吗？").fontSize(12).fontColor('#999999')
              Text("开始新一轮").fontSize(12).fontColor('#007DFF')
                .onClick(() => {
                  RouterModule.popToName("Page9");
                })
            }
          }
          .width('100%')
          .padding({ bottom: 48 }) // 给滚动留出底部安全区
          .backgroundColor('#F6F6F8')
        }
      }
      .columnsTemplate("1fr")
      .rowsGap(0)
      .padding({ left: 0, right: 0 })
      .width('100%')
      .layoutWeight(1)
      .scrollBar(BarState.Off)
    }
    .width('100%')
    .height('100%')
    .backgroundColor('#F6F6F8')
    .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])
  }
}
