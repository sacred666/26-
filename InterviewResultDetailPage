import { AppTheme } from '../constants/AppTheme'
import { RouterModule } from '../utils/RouterModule'

// ==========================================
// 1. 严格模式数据类定义
// ==========================================

export class HighlightDetail {
  personalStatus: string[] = []; // ❤️ 个人状态
  questionTags: string[] = [];   // 🏷️ 题目标签
  improveAdvice: string = '';    // 🌟 针对【高亮部分】的具体改善建议
  scriptInfo: string = '';
  voiceAnalysis: string = '';    // 🎙️ 语音分析
}

export class AnswerSegment {
  text: string = '';
  isHighlight: boolean = false;
  detailData?: HighlightDetail;
}

export class QuestionData {
  id: string = '';
  num: number = 0;
  score: number = 0;
  time: string = '';
  questionText: string = '';
  answerSegments: AnswerSegment[] = [];
  overallImproveAdvice: string = '';
}

export class CardStyle {
  isHigh: boolean = false;
  mainColor: string = '';
  faintColor: string = '';
  highlightBg: string = '';
  gradColor1: string = '';
  gradColor2: string = '';
  gradColor3: string = '';
  badgeBg: string = '';
  shadowColor: string = '';
}

// ==========================================
// 2. 独立的单题卡片组件
// ==========================================
@Component
struct QuestionCardView {
  @Prop item: QuestionData;
  @Prop cardStyle: CardStyle;

  @State isActive: boolean = false;

  @Builder
  TagModuleBuilder(data: HighlightDetail) {
    Column({ space: 12 }) {
      // 1. 顶部两等分小卡片
      Row({ space: 12 }) {
        Column() {
          Text("个人状态").fontSize(11).fontColor(this.cardStyle.mainColor).opacity(0.7).margin({ bottom: 6 })
          Column({ space: 4 }) {
            ForEach(data.personalStatus || [], (tag: string) => {
              Text(tag).fontSize(13).fontColor(this.cardStyle.mainColor).fontWeight(FontWeight.Bold)
            })
          }
          .alignItems(HorizontalAlign.Start)
        }
        .layoutWeight(1).alignItems(HorizontalAlign.Start)
        .padding(14).backgroundColor('rgba(255,255,255,0.95)').borderRadius(12)
        .border({ width: 0.5, color: '#F0F0F0' })
        .shadow({ radius: 12, color: 'rgba(0,0,0,0.1)', offsetY: 4, offsetX: 0 })

        Column() {
          Text("题目标签").fontSize(11).fontColor(this.cardStyle.mainColor).opacity(0.7).margin({ bottom: 6 })
          Column({ space: 4 }) {
            ForEach(data.questionTags || [], (tag: string) => {
              Text(tag).fontSize(13).fontColor(this.cardStyle.mainColor).fontWeight(FontWeight.Bold)
            })
          }
          .alignItems(HorizontalAlign.Start)
        }
        .layoutWeight(1).alignItems(HorizontalAlign.Start)
        .padding(14).backgroundColor('rgba(255,255,255,0.95)').borderRadius(12)
        .border({ width: 0.5, color: '#F0F0F0' })
        .shadow({ radius: 12, color: 'rgba(0,0,0,0.1)', offsetY: 4, offsetX: 0 })
      }
      .width('100%')

      // 2. 改善建议
      Column() {
        Text("改善建议").fontSize(11).fontColor(this.cardStyle.mainColor).opacity(0.7).margin({ bottom: 6 })
        Text(data.improveAdvice).fontSize(15).fontColor(this.cardStyle.mainColor).lineHeight(20)
      }
      .width('100%').alignItems(HorizontalAlign.Start)
      .padding(14).backgroundColor('rgba(255,255,255,0.95)').borderRadius(12)
      .border({ width: 0.5, color: '#F0F0F0' })
      .shadow({ radius: 12, color: 'rgba(0,0,0,0.1)', offsetY: 4, offsetX: 0 })

      // 3. 相关话术
      Column() {
        Text("相关话术").fontSize(11).fontColor(this.cardStyle.mainColor).opacity(0.7).margin({ bottom: 6 })
        Row({ space: 8 }) {
          Image($r("app.media.6666"))
            .width(28).height(28)
          Text(data.scriptInfo || '').fontSize(13).fontColor(this.cardStyle.mainColor).lineHeight(20).layoutWeight(1)
        }
      }
      .width('100%').alignItems(HorizontalAlign.Start)
      .padding(14).backgroundColor('rgba(255,255,255,0.95)').borderRadius(12)
      .border({ width: 0.5, color: '#F0F0F0' })
      .shadow({ radius: 12, color: 'rgba(0,0,0,0.1)', offsetY: 4, offsetX: 0 })

      // 4. 语音分析
      Column() {
        Text("语音分析").fontSize(11).fontColor(this.cardStyle.mainColor).opacity(0.7).margin({ bottom: 6 })
        Row({ space: 8 }) {
          Image($r("app.media.Player"))
            .width(28).height(28)
          Text(data.voiceAnalysis || '').fontSize(13).fontColor(this.cardStyle.mainColor).lineHeight(20).layoutWeight(1)
        }
      }
      .width('100%').alignItems(HorizontalAlign.Start)
      .padding(14).backgroundColor('rgba(255,255,255,0.95)').borderRadius(12)
      .border({ width: 0.5, color: '#F0F0F0' })
      .shadow({ radius: 12, color: 'rgba(0,0,0,0.1)', offsetY: 4, offsetX: 0 })

      // 5. 能力变化
      Column() {
        Text("能力变化").fontSize(11).fontColor(this.cardStyle.mainColor).opacity(0.7).margin({ bottom: 8 })
        Image($r("app.media.Detailed"))
          .width('100%')
          .height(160)
          .objectFit(ImageFit.Contain)
          .borderRadius(8)
      }
      .width('100%').alignItems(HorizontalAlign.Start)
      .padding(14).backgroundColor('rgba(255,255,255,0.95)').borderRadius(12)
      .border({ width: 0.5, color: '#F0F0F0' })
      .shadow({ radius: 12, color: 'rgba(0,0,0,0.1)', offsetY: 4, offsetX: 0 })
    }
    .width('100%')
  }

  build() {
    Stack({ alignContent: Alignment.TopEnd }) {

      // --- 底层：完整的卡片容器 ---
      Column() {
        Column({ space: 16 }) {

          // --- 题号 ---
          Text(`问题 ${this.item.num}`)
            .fontSize(20)
            .fontWeight(FontWeight.Bold)
            .fontColor(this.cardStyle.mainColor)
            .width('100%')
            .padding({ left: 4, top: 4 })

          // --- 1. 问题框 ---
          Column() {
            Row() {
              Text("问题").fontSize(12).fontColor(this.cardStyle.mainColor).margin({ right: 6 }).opacity(0.8)
              Text(this.item.time).fontSize(12).fontColor(this.cardStyle.mainColor).opacity(0.8)
            }
            .backgroundColor('rgba(255,255,255,0.7)')
            .padding({ left: 10, right: 10, top: 4, bottom: 4 })
            .borderRadius(12)
            .margin({ bottom: 12 })

            Text(this.item.questionText)
              .fontSize(17)
              .fontWeight(FontWeight.Bold)
              .fontColor(this.cardStyle.mainColor)
              .lineHeight(22)
              .width('100%')
          }
          .width('100%')
          .alignItems(HorizontalAlign.Start)
          .padding(16)
          .backgroundColor('rgba(255, 255, 255, 0.6)')
          .borderRadius(16)

          // --- 2. 答案框 ---
          Column() {
            Row() {
              Text("回答").fontSize(12).fontColor(this.cardStyle.mainColor).margin({ right: 6 }).opacity(0.8)
              Text("00:00:00").fontSize(12).fontColor(this.cardStyle.mainColor).opacity(0.8)
            }
            .backgroundColor('rgba(255,255,255,0.7)')
            .padding({ left: 10, right: 10, top: 4, bottom: 4 })
            .borderRadius(12)
            .margin({ bottom: 12 })

            ForEach(this.item.answerSegments, (seg: AnswerSegment, index: number) => {
              if (seg.isHighlight) {
                Column() {
                  Text(seg.text)
                    .backgroundColor(this.cardStyle.highlightBg)
                    .fontColor(this.cardStyle.mainColor)
                    .fontWeight(FontWeight.Bold)
                    .fontSize(15)
                    .lineHeight(20)
                    .width('100%')
                    .onClick(() => {
                      animateTo({ duration: 300, curve: Curve.EaseInOut }, () => {
                        this.isActive = !this.isActive;
                      });
                    })

                  if (this.isActive) {
                    Column() {
                      this.TagModuleBuilder(seg.detailData as HighlightDetail)
                    }
                    .margin({ top: 16, bottom: 16 })
                  }
                }
                .width('100%')
              } else {
                Text(seg.text)
                  .fontColor(this.isActive ? this.cardStyle.faintColor : this.cardStyle.mainColor)
                  .fontWeight(FontWeight.Normal)
                  .fontSize(15)
                  .lineHeight(20)
                  .width('100%')
              }
            })
          }
          .width('100%')
          .alignItems(HorizontalAlign.Start)
          .padding(16)
          .backgroundColor('rgba(255, 255, 255, 0.6)')
          .borderRadius(16)

          // --- 3. 改善建议框 ---
          Column() {
            Text("改善建议")
              .fontSize(12)
              .fontColor(this.isActive ? this.cardStyle.faintColor : this.cardStyle.mainColor)
              .fontWeight(FontWeight.Bold)
              .margin({ bottom: 8 })

            Text(this.item.overallImproveAdvice)
              .fontSize(15)
              .fontColor(this.isActive ? this.cardStyle.faintColor : this.cardStyle.mainColor)
              .lineHeight(20)
              .width('100%')
          }
          .width('100%')
          .alignItems(HorizontalAlign.Start)
          .padding(16)
          .backgroundColor('rgba(255, 255, 255, 0.6)')
          .borderRadius(16)

        }
        .width('100%')
        .padding(20)
        .radialGradient({
          center: ['100%', '0%'],
          radius: '120%',
          colors: [
            [this.cardStyle.gradColor1, 0.0],
            [this.cardStyle.gradColor2, 0.4],
            [this.cardStyle.gradColor3, 1.0]
          ]
        })
        .borderRadius(24)
        .shadow({ radius: 30, color: this.cardStyle.shadowColor, offsetY: 10, offsetX: 0 })
      }
      .width('100%')
      .padding({ left: 16, right: 16, top: 22 }) // 内部卡片边距 16，避开屏幕边缘，同时留出 top 给勋章

      // --- 顶层：得分勋章 ---
      Stack({ alignContent: Alignment.Center }) {
        Circle({ width: 44, height: 44 }).fill(this.cardStyle.badgeBg)
        Circle({ width: 36, height: 36 }).fill(Color.White)
        Text(`${this.item.score}`)
          .fontSize(16)
          .fontWeight(FontWeight.Bold)
          .fontColor(this.cardStyle.mainColor)
      }
      .margin({ top: 0, right: 4 }) // 不会被裁剪

    }
    .width('100%')
    .padding({ bottom: 16 })
  }
}

// ==========================================
